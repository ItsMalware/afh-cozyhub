{
  "name": "cozyhub-oss",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22 <24"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:mobile:web": "NEXT_OUTPUT_MODE=export next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:release-smoke",
    "test:e2e": "playwright test",
    "test:release-smoke": "playwright test tests/e2e/release-smoke.spec.ts --workers=1",
    "release:check": "npm run lint && npm run typecheck && npm run build",
    "antigravity": "node tools/antigravity/server.js",
    "reme:status": ".venv-reme/bin/python tools/reme/reme_bridge.py --config tools/reme/config.yaml status",
    "reme:add": ".venv-reme/bin/python tools/reme/reme_bridge.py --config tools/reme/config.yaml add",
    "reme:retrieve": ".venv-reme/bin/python tools/reme/reme_bridge.py --config tools/reme/config.yaml retrieve",
    "reme:serve": ".venv-reme/bin/python tools/reme/reme_bridge.py --config tools/reme/config.yaml serve",
    "langextract:status": ".venv-langextract/bin/python tools/langextract/langextract_bridge.py status",
    "langextract:extract": ".venv-langextract/bin/python tools/langextract/langextract_bridge.py extract",
    "gws:status": "npx gws auth status",
    "gws:login": "npx gws auth login -s drive,gmail,sheets,calendar,docs,slides,tasks,chat",
    "gws:setup": "npx gws auth setup --login",
    "gws:smoke": "bash tools/gws/smoke.sh",
    "cap:sync": "npx cap sync android",
    "android:sync": "npm run build:mobile:web && npx cap sync android",
    "cap:open:android": "npx cap open android",
    "android:apk:debug": "cd android && ./gradlew assembleDebug",
    "mac:tauri:init": "npx tauri init --ci",
    "mac:tauri:build": "npm run build:mobile:web && npx tauri build"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@notionhq/client": "^5.11.1",
    "@udecode/plate": "^48.0.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "firebase-admin": "^13.7.0",
    "lucide-react": "^0.577.0",
    "motion": "^12.35.1",
    "next": "16.2.1",
    "notebooklm-mcp": "^1.2.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@googleworkspace/cli": "^0.9.1",
    "@playwright/test": "^1.54.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "overrides": {
    "@tootallnate/once": "3.0.1",
    "fast-xml-parser": "5.5.8",
    "hono": "4.12.8",
    "tar": "7.5.12"
  }
}
